# Server Configuration
SERVER_NAME=Paradex Trading
SERVER_PORT=3000

# Paradex Configuration
# Options: testnet, mainnet
PARADEX_ENVIRONMENT=testnet

# Authentication — choose one of three modes:

# Mode 1: Private key (original mode)
PARADEX_ACCOUNT_PRIVATE_KEY=

# Mode 2: Static JWT token (from Paradex SIWE login, for non-HTTP deployments)
PARADEX_JWT_TOKEN=

# Mode 3: OAuth 2.1 Resource Server (HTTP transport only)
# Canonical URL of this MCP server (returned in /.well-known/oauth-protected-resource)
MCP_SERVER_URL=
# OAuth Authorization Server URL (e.g. https://api.prod.paradex.trade)
PARADEX_AUTH_SERVER_URL=